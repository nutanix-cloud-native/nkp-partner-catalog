{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": ["nodejs@20"],
  "shell": {
    "init_hook": ["echo 'Welcome to devbox!' > /dev/null"],
    "scripts": {
      "install": ["npm install --ignore-scripts"],
      "start": ["npm run start"],
      "build": ["npm run build"],
      "serve": ["npm run serve"]
    }
  }
}
